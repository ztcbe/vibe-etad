# Database
DATABASE_URL=postgresql+asyncpg://zvibe:zvibe@localhost:5432/zvibe

# JWT
JWT_SECRET=change-me-to-a-strong-random-string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ═══════════════════════════════════════
# LLM Defaults (shared config)
# All per-agent configs fall back to these if not set.
# ═══════════════════════════════════════
LLM_BASE_URL=https://your-llm-provider.example.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name
LLM_MAX_TOKENS=65535

# ═══════════════════════════════════════
# CoordinatorAgent — entry point, general chat, routing
# Falls back to LLM_* if not set.
# ═══════════════════════════════════════
# COORDINATOR_LLM_MODEL=
# COORDINATOR_LLM_API_KEY=
# COORDINATOR_LLM_BASE_URL=
# COORDINATOR_LLM_MAX_TOKENS=
COORDINATOR_TEMPERATURE=0.8
COORDINATOR_MAX_OUTPUT_TOKENS=1500

# ═══════════════════════════════════════
# MatchmakerAgent — search, scoring, like/pass
# Falls back to LLM_* if not set.
# ═══════════════════════════════════════
# MATCHMAKER_LLM_MODEL=
# MATCHMAKER_LLM_API_KEY=
# MATCHMAKER_LLM_BASE_URL=
# MATCHMAKER_LLM_MAX_TOKENS=
MATCHMAKER_TEMPERATURE=0.6
MATCHMAKER_MAX_OUTPUT_TOKENS=1500

# ═══════════════════════════════════════
# ConversationCoachAgent — reply suggestions, tone-aware
# Falls back to LLM_* if not set.
# ═══════════════════════════════════════
# COACH_LLM_MODEL=
# COACH_LLM_API_KEY=
# COACH_LLM_BASE_URL=
# COACH_LLM_MAX_TOKENS=
COACH_TEMPERATURE=1.0
COACH_MAX_OUTPUT_TOKENS=1000

# ═══════════════════════════════════════
# BotAgent — auto-reply for demo/seed bot users
# Falls back to LLM_* if not set.
# ═══════════════════════════════════════
# BOT_LLM_MODEL=
# BOT_LLM_API_KEY=
# BOT_LLM_BASE_URL=
# BOT_LLM_MAX_TOKENS=
BOT_TEMPERATURE=0.9
BOT_MAX_OUTPUT_TOKENS=250
BOT_REPLY_DELAY_MIN=2.0
BOT_REPLY_DELAY_MAX=8.0

# Media
MEDIA_UPLOAD_DIR=./uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# App
APP_ENV=development
